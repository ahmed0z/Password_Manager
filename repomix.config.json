{
  "output": {
    "filePath": "repomix-output.txt",
    "style": "markdown",
    "showLineNumbers": true,
    "removeComments": false
  },
  "ignore": {
    "customPatterns": [
      "**/node_modules/**",
      "**/dist/**",
      "**/build/**",
      "**/.next/**",
      "**/.expo/**",
      "**/*.lock",
      "**/coverage/**",
      "**/repomix-output.txt",
      "**/.env",
      "**/.env.local"
    ]
  },
  "include": [
    "packages/**/*.{ts,tsx,css,json}",
    "apps/**/*.{ts,tsx,css,json,html}",
    "supabase/**/*.sql"
  ]
}
