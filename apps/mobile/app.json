{
  "expo": {
    "name": "VaultSync",
    "slug": "vaultsync-mobile",
    "version": "1.0.9",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "scheme": "vaultsync",
    "backgroundColor": "#4A515C",
    "splash": {
      "backgroundColor": "#4A515C"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.vaultsync.mobile"
    },
    "android": {
      "backgroundColor": "#4A515C",
      "adaptiveIcon": {
        "backgroundColor": "#4A515C"
      },
      "package": "com.vaultsync.mobile"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
